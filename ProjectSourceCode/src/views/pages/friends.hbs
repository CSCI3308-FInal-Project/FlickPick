<main class="profile-page">
  <div class="profile-container">
    <section class="profile-header">
      <h1>Friends</h1>
    </section>

    {{#if pendingCount}}
    <section class="pending-requests-section">
      <h2 class="section-heading">Pending Requests <span class="pending-badge">{{pendingCount}}</span></h2>
      <ul class="pending-list">
        {{#each pendingRequests}}
        <li class="pending-item" data-id="{{this.id}}">
          <span class="pending-username">{{this.username}} wants to be friends</span>
          <div class="pending-actions">
            <button class="btn-accept" onclick="acceptFriend({{this.id}}, this)">Accept</button>
            <button class="btn-decline" onclick="declineFriend({{this.id}}, this)">Decline</button>
          </div>
        </li>
        {{/each}}
      </ul>
    </section>
    {{/if}}

    <section class="info-card">
      <h3>Add Friend</h3>
      <form id="addFriendForm" class="profile-details">
        <input
          type="text"
          id="friendUsername"
          name="username"
          placeholder="Enter username"
          required
        />
        <button type="submit" class="btn-primary">Add Friend</button>
      </form>
    </section>

    <section class="info-card">
      <h3>Your Friends</h3>
      {{#if friends.length}}
        <div class="profile-details">
          {{#each friends}}
            <div class="friend-card">
              <p><strong>Username:</strong> {{this.username}}</p>
              <p><strong>Name:</strong> {{this.name}}</p>
              <p><strong>Bio:</strong> {{this.bio}}</p>
              <p><strong>Favorite Movies:</strong> {{this.favorite_movies}}</p>
              <p><strong>Favorite Genres:</strong> {{this.favorite_genres}}</p>
              <a href="/users/{{this.username}}" class="btn-primary">View Profile</a>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p>No friends yet.</p>
      {{/if}}
    </section>
  </div>
</main>

<script src="/js/friends.js"></script>

<script>
function acceptFriend(friendId, btn) {
  fetch(`/friends/accept/${friendId}`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const item = btn.closest('.pending-item');
        item.remove();
        const badge = document.querySelector('.pending-badge');
        if (badge) {
          const n = parseInt(badge.textContent) - 1;
          if (n <= 0) document.querySelector('.pending-requests-section').remove();
          else badge.textContent = n;
        }
        location.reload();
      }
    });
}

function declineFriend(friendId, btn) {
  fetch(`/friends/decline/${friendId}`, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const item = btn.closest('.pending-item');
        item.remove();
        const badge = document.querySelector('.pending-badge');
        if (badge) {
          const n = parseInt(badge.textContent) - 1;
          if (n <= 0) document.querySelector('.pending-requests-section').remove();
          else badge.textContent = n;
        }
      }
    });
}
</script>