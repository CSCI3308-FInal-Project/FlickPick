<div class="watchlist-container">
  <div class="watchlist-header">
    <h1 class="watchlist-title">{{#if tabWatched}}Watched{{else}}My Watchlist{{/if}}</h1>
    <p class="watchlist-subtitle">
      {{#if tabWatched}}{{watchedCount}} watched movies{{else}}{{watchlistCount}} saved movies{{/if}}
    </p>
  </div>

  <!-- Tabs -->
  <div class="watchlist-tabs">
    <a href="/watchlist?tab=watchlist" class="tab-link {{#if tabWatchlist}}tab-active{{/if}}">
      My Watchlist <span class="tab-count">{{watchlistCount}}</span>
    </a>
    <a href="/watchlist?tab=watched" class="tab-link {{#if tabWatched}}tab-active{{/if}}">
      Watched <span class="tab-count">{{watchedCount}}</span>
    </a>
  </div>

  {{#if tabWatchlist}}
    {{#if watchlist.length}}
    <div class="search-bar">
      <input type="text" id="watchlistSearch" placeholder="Search your watchlist…" />
      <select id="genreFilter">
        <option value="">All Genres</option>
      </select>
    </div>
    <div id="bulkBar" class="bulk-bar" style="display:none">
      <label class="bulk-select-all">
        <input type="checkbox" id="selectAll" /> Select All
      </label>
      <button id="bulkWatchBtn" class="btn-bulk-watch">✓ Mark as Watched</button>
      <button id="bulkDeleteBtn" class="btn-bulk-delete">✕ Delete Selected</button>
    </div>
    <div class="sort-bar">
      <label for="sortSelect">Sort by:</label>
      <select id="sortSelect">
        <option value="default">Date Added</option>
        <option value="rating">Rating (High → Low)</option>
        <option value="alpha">Alphabetical (A → Z)</option>
      </select>
    </div>
    <div class="movie-list" id="movieList">
      {{#each watchlist}}
      <div class="movie-row"
        data-id="{{this.id}}"
        data-title="{{this.title}}"
        data-genre="{{this.genre}}"
        data-movie-id="{{this.movie_id}}"
        data-poster="{{this.poster_url}}"
        data-year="{{this.year}}"
        data-rating="{{this.rating}}"
        data-synopsis="{{this.synopsis}}"
        data-watched="false">

        <input type="checkbox" class="row-check" data-id="{{this.id}}" data-title="{{this.title}}" />
        <div class="movie-poster">
          {{#if this.poster_url}}
          <img src="{{this.poster_url}}" alt="{{this.title}} poster" />
          {{else}}
          🎬
          {{/if}}
        </div>

        <div class="movie-info">
          <div class="movie-title">{{this.title}}</div>
          <div class="movie-meta">
            {{this.genre}}{{#if this.year}} &bull; {{this.year}}{{/if}}{{#if this.rating}} &bull; ★ {{this.rating}}{{/if}}
          </div>
        </div>

        <div class="movie-actions">
          <div class="tip-btn">
            <button class="btn-details" onclick="openModal(this.closest('.movie-row'))">Details</button>
            <div class="tooltip">View more details</div>
          </div>
          <div class="tip-btn">
            <form method="POST" action="/watchlist/{{this.id}}" style="display:contents">
              <input type="hidden" name="_method" value="DELETE" />
              <input type="hidden" name="_tab" value="watchlist" />
              <button type="submit" class="btn-remove">✕</button>
            </form>
            <div class="tooltip">Remove from watchlist</div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{#if showPagination}}
    <div class="pagination">
      {{#if hasPrev}}<a href="/watchlist?tab=watchlist&page={{prevPage}}" class="btn-page">← Prev</a>{{/if}}
      <span class="page-info">Page {{currentPage}} of {{totalPages}}</span>
      {{#if hasNext}}<a href="/watchlist?tab=watchlist&page={{nextPage}}" class="btn-page">Next →</a>{{/if}}
    </div>
    {{/if}}
    {{else}}
    <div class="empty-state">
      <p>Your watchlist is empty.</p>
      <p><a href="/">Discover movies →</a></p>
    </div>
    {{/if}}
  {{/if}}

  {{#if tabWatched}}
    {{#if watched.length}}
    <div class="search-bar">
      <input type="text" id="watchlistSearch" placeholder="Search watched movies…" />
      <select id="genreFilter">
        <option value="">All Genres</option>
      </select>
    </div>
    <div id="bulkBar" class="bulk-bar" style="display:none">
      <label class="bulk-select-all">
        <input type="checkbox" id="selectAll" /> Select All
      </label>
      <button id="bulkDeleteBtn" class="btn-bulk-delete">✕ Delete Selected</button>
    </div>
    <div class="sort-bar">
      <label for="sortSelect">Sort by:</label>
      <select id="sortSelect">
        <option value="default">Date Added</option>
        <option value="rating">Rating (High → Low)</option>
        <option value="alpha">Alphabetical (A → Z)</option>
      </select>
    </div>
    <div class="movie-list" id="movieList">
      {{#each watched}}
      <div class="movie-row"
        data-id="{{this.id}}"
        data-title="{{this.title}}"
        data-genre="{{this.genre}}"
        data-movie-id="{{this.movie_id}}"
        data-poster="{{this.poster_url}}"
        data-year="{{this.year}}"
        data-rating="{{this.rating}}"
        data-synopsis="{{this.synopsis}}"
        data-watched="true">

        <input type="checkbox" class="row-check" data-id="{{this.id}}" data-title="{{this.title}}" />
        <div class="movie-poster">
          {{#if this.poster_url}}
          <img src="{{this.poster_url}}" alt="{{this.title}} poster" />
          {{else}}
          🎬
          {{/if}}
        </div>

        <div class="movie-info">
          <div class="movie-title">{{this.title}}</div>
          <div class="movie-meta">
            {{this.genre}}{{#if this.year}} &bull; {{this.year}}{{/if}}{{#if this.rating}} &bull; ★ {{this.rating}}{{/if}}
          </div>
        </div>

        <div class="movie-actions">
          <div class="tip-btn">
            <button class="btn-details" onclick="openModal(this.closest('.movie-row'))">Details</button>
            <div class="tooltip">View more details</div>
          </div>
          <div class="tip-btn">
            <form method="POST" action="/watchlist/{{this.id}}" style="display:contents">
              <input type="hidden" name="_method" value="DELETE" />
              <input type="hidden" name="_tab" value="watched" />
              <button type="submit" class="btn-remove">✕</button>
            </form>
            <div class="tooltip">Remove from watched list</div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{#if showPagination}}
    <div class="pagination">
      {{#if hasPrev}}<a href="/watchlist?tab=watched&page={{prevPage}}" class="btn-page">← Prev</a>{{/if}}
      <span class="page-info">Page {{currentPage}} of {{totalPages}}</span>
      {{#if hasNext}}<a href="/watchlist?tab=watched&page={{nextPage}}" class="btn-page">Next →</a>{{/if}}
    </div>
    {{/if}}
    {{else}}
    <div class="empty-state">
      <p>No watched movies yet.</p>
      <p><a href="/watchlist?tab=watchlist">Go to your watchlist →</a></p>
    </div>
    {{/if}}
  {{/if}}
</div>

<!-- Details Modal -->
<div class="modal-backdrop" id="modalBackdrop" onclick="closeModalOnBackdrop(event)">
  <div class="modal" id="detailsModal">
    <div class="modal-header">
      <div class="modal-poster" id="modalPoster">🎬</div>
      <div class="modal-title-block">
        <div class="modal-title" id="modalTitle"></div>
        <div class="modal-meta" id="modalMeta"></div>
        <div class="modal-rating" id="modalRating"></div>
        <a href="#" class="tmdb-badge" id="modalTmdbLink" target="_blank" rel="noopener noreferrer">↗ TMDb</a>
      </div>
    </div>
    <div class="modal-body">
      <div class="modal-loading" id="modalLoading">Loading details…</div>
      <div class="modal-details" id="modalDetails" style="display:none">
        <p class="modal-synopsis" id="modalSynopsis"></p>
        <p class="modal-director" id="modalDirector"></p>
        <p class="modal-cast" id="modalCast"></p>
      </div>
      <div class="modal-error" id="modalError" style="display:none">
        Couldn't load details. Try again later.
      </div>
    </div>
    <div class="modal-footer">
      <form method="POST" id="modalDeleteForm" style="display:contents">
        <input type="hidden" name="_method" value="DELETE" />
        <input type="hidden" name="_tab" id="modalDeleteTab" value="watchlist" />
        <button type="submit" class="btn-remove-modal">✕ Remove</button>
      </form>
      <form method="POST" id="modalWatchForm" style="display:contents">
        <button type="submit" class="btn-watch-modal" id="modalWatchBtn"></button>
      </form>
      <button class="btn-close" onclick="closeModal()">Close</button>
    </div>
  </div>
</div>
