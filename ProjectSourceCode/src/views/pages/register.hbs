<div class="auth-container">
  <h1 class="auth-title">Create Account</h1>
  <p class="auth-subtitle">Join FlickPick and start swiping</p>

  {{#if message}}
  <div class="alert">{{message}}</div>
  {{/if}}

  <form action="/register" method="POST" class="auth-form">
    <div class="form-group">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" required autocomplete="username" />
    </div>
    <div class="form-group">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required autocomplete="email" />
    </div>
    <div class="form-group">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required autocomplete="new-password" />
    </div>
    <div class="form-group">
      <label for="confirmPassword">Confirm Password</label>
      <input type="password" id="confirmPassword" name="confirmPassword" required autocomplete="new-password" />
    </div>
    <div id="passwordError" style="color: red; display: none; margin-top: 5px;">
       Passwords do not match. Try again.
    </div>
    <button type="submit" class="btn-primary">Create Account</button>
  </form>

  <p class="switch-auth">Already have an account? <a href="/login">Sign In</a></p>
</div>

<script>
  const enter_password = document.getElementById("password");
  const confirm_password = document.getElementById("confirmPassword");
  const error = document.getElementById("passwordError");

  //if the password field is filled and password and confirm password don't match an error message will appear when the field is left and everything will be cleared.
  confirm_password.addEventListener("blur", function () {
    const password = enter_password.value;
    const confirm = confirm_password.value;
    
    if (confirm !== "" && password !== confirm) {
      error.style.display = "block";
      confirm_password.value = ""; 
    } else {
      error.style.display = "none";
    }
  });

  confirm_password.addEventListener("input", function () {
    error.style.display = "none";
  });
</script>