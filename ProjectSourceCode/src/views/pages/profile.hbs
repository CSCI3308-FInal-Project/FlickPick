<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FlickPick | Profile</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

  <main class="profile-page">
    <div class="profile-container">
      <section class="profile-header">
        <h1>My Profile</h1>
        <h2>Username: <span id="username">{{user.username}}</span></h2>
        <button type="button" id="editProfileBtn" class="btn-primary">Edit Profile</button>
      </section>

      <section class="info-card">
        <h3>About Me</h3>
        <div class="profile-details">
          <p><strong>Name:</strong> <span id="name">{{profile.name}}</span></p>
          <p><strong>Age:</strong> <span id="age">{{profile.age}}</span></p>
          <p><strong>Gender:</strong> <span id="gender">{{profile.gender}}</span></p>
          <p><strong>Bio:</strong> <span id="bio">{{profile.bio}}</span></p>
        </div>
      </section>

      <section class="info-card">
        <h3>Favorites</h3>
        <div class="profile-details">
          <p><strong>Movies:</strong> <span id="favoriteMovies">{{profile.favorite_movies}}</span></p>
          <p><strong>Genres:</strong> <span id="favoriteGenres">{{profile.favorite_genres}}</span></p>
        </div>
      </section>

      <section class="info-card">
        <h3>Swipe History Stats</h3>
        <p>Total Swipes: <span id="totalSwipes">TBD</span></p>
        <p>Right Swipes: <span id="rightSwipes">TBD</span></p>
        <p>Left Swipes: <span id="leftSwipes">TBD</span></p>
      </section>

      <button id="logoutBtn" class="logout-btn">Logout</button>
    </div>
  </main>

  <script src="/js/profile.js"></script>

</html>