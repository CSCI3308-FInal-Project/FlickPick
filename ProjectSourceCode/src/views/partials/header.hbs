<header class="site-header">
  <nav class="navbar">
    <a href="/" class="logo">FlickPick</a>
    {{#if user}}
    <div class="nav-links">
      <a href="/" class="nav-link {{#if (eq activePage 'home')}}nav-active{{/if}}">Home</a>
      <a href="/watchlist" class="nav-link {{#if (eq activePage 'watchlist')}}nav-active{{/if}}">Watchlist</a>
      <a href="/group-sessions" class="nav-link {{#if (eq activePage 'group-sessions')}}nav-active{{/if}}">Group Sessions</a>
      <div class="nav-dropdown notif-dropdown" id="notifDropdown">
        <button class="notif-icon-btn" aria-label="Notifications" id="notifBtn">
          <span class="bell-icon">🔔</span>
          <span class="notif-badge" id="notifBadge" style="display:none">0</span>
        </button>
        <div class="dropdown-menu notif-menu" id="notifMenu">
          <div class="notif-header">
            <h4>Notifications</h4>
            <button class="btn-mark-all" id="markAllReadBtn">Mark all read</button>
          </div>
          <div class="notif-list" id="notifList">
            <div class="notif-empty">You're all caught up</div>
          </div>
        </div>
      </div>

      <div class="nav-dropdown profile-dropdown">
        <button class="profile-icon-btn" aria-label="Account menu">
          <span class="profile-initial">{{user.username.[0]}}</span>
        </button>
        <div class="dropdown-menu profile-menu">
          <a href="/profile" class="dropdown-item">My Profile</a>
          <a href="/friends" class="dropdown-item">Friends</a>
          <a href="/logout" class="dropdown-item dropdown-item--danger">Logout</a>
        </div>
      </div>
    </div>
    {{/if}}
  </nav>
</header>
